{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": { "enabled": false, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": false,
    "ignore": ["node_modules", ".next", "dist", "build", "docs/reference"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": { "useImportType": "off" },
      "suspicious": { "noExplicitAny": "off", "noArrayIndexKey": "off" },
      "a11y": { "useKeyWithClickEvents": "off", "useSemanticElements": "off" }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double", "jsxQuoteStyle": "double", "semicolons": "always" }
  }
}
